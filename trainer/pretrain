import os
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader
from torchvision import transforms, datasets
import timm
from tqdm import tqdm
from torch.nn.functional import interpolate

os.environ['HF_ENDPOINT'] = 'https://hf-mirror.com'


def load_pets_dataset(batch_size=32, img_size=384):
    transform = transforms.Compose([
        transforms.Resize((img_size, img_size)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
    ])

    train_dataset = datasets.OxfordIIITPet(
        root="./data",
        split="trainval",
        transform=transform,
        download=True
    )
    test_dataset = datasets.OxfordIIITPet(
        root="./data",
        split="test",
        transform=transform,
        download=True
    )

    train_loader = DataLoader(
        train_dataset,
        batch_size=batch_size,
        shuffle=True,
        num_workers=4,
        pin_memory=True,
        persistent_workers=True
    )
    test_loader = DataLoader(
        test_dataset,
        batch_size=batch_size,
        shuffle=False,
        num_workers=4,
        pin_memory=True,
        persistent_workers=True
    )
    return train_loader, test_loader


def init_vit_model(num_classes=37, img_size=384):
    model = timm.create_model("vit_base_patch16_224_in21k", pretrained=False)
    state_dict = torch.load("../pretrain_model/vit_base_patch16_224_in21k.bin")
    model.load_state_dict(state_dict, strict=False)

    model.head = nn.Linear(model.head.in_features, num_classes)
    nn.init.zeros_(model.head.weight)

    if img_size != 224:
        patch_size = model.patch_embed.patch_size[0]
        orig_size = 224 // patch_size
        new_size = img_size // patch_size

        pos_embed = model.pos_embed
        if pos_embed.shape[1] == orig_size ** 2 + 1:
            cls_token = pos_embed[:, :1, :]
            pos_embed = pos_embed[:, 1:, :]
            pos_embed = pos_embed.reshape(1, orig_size, orig_size, -1).permute(0, 3, 1, 2)
            pos_embed = interpolate(pos_embed, size=(new_size, new_size), mode='bilinear')
            pos_embed = pos_embed.permute(0, 2, 3, 1).reshape(1, new_size * new_size, -1)
            pos_embed = torch.cat([cls_token, pos_embed], dim=1)
        else:
            pos_embed = pos_embed.reshape(1, orig_size, orig_size, -1).permute(0, 3, 1, 2)
            pos_embed = interpolate(pos_embed, size=(new_size, new_size), mode='bilinear')
            pos_embed = pos_embed.permute(0, 2, 3, 1).reshape(1, new_size * new_size, -1)

        model.pos_embed = nn.Parameter(pos_embed)
        model.patch_embed.img_size = (img_size, img_size)
        model.patch_embed.grid_size = (new_size, new_size)

    return model


def fine_tune(
        model,
        train_loader,
        test_loader,
        model_save_path,
        epochs=100,
        lr=0.03,
        momentum=0.9,
        weight_decay=0.0,
        grad_clip=1.0,
        batch_size=64,
        target_batch_size=512,
):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model = model.to(device)
    criterion = nn.CrossEntropyLoss()

    grad_accum_steps = max(1, target_batch_size // batch_size)
    print(
        f"Using gradient accumulation: {grad_accum_steps} steps (batch_size={batch_size} -> effective_batch={batch_size * grad_accum_steps})")

    optimizer = optim.SGD(
        model.parameters(),
        lr=lr * grad_accum_steps,
        momentum=momentum,
        weight_decay=weight_decay
    )

    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)

    best_acc = 0.0
    for epoch in range(epochs):
        model.train()
        train_loss = 0.0
        optimizer.zero_grad()

        train_bar = tqdm(train_loader, desc=f"Epoch {epoch + 1}/{epochs}")
        for step, (images, labels) in enumerate(train_bar):
            images, labels = images.to(device), labels.to(device)
            outputs = model(images)
            loss = criterion(outputs, labels) / grad_accum_steps
            loss.backward()

            train_loss += loss.item() * grad_accum_steps

            if (step + 1) % grad_accum_steps == 0 or (step + 1) == len(train_loader):
                nn.utils.clip_grad_norm_(model.parameters(), grad_clip)
                optimizer.step()
                optimizer.zero_grad()

            train_bar.set_postfix({
                "Loss": f"{train_loss / (step + 1):.4f}",
                "LR": f"{optimizer.param_groups[0]['lr']:.4f}"
            })

        scheduler.step()

        model.eval()
        correct = 0
        total = 0
        with torch.no_grad():
            for images, labels in tqdm(test_loader, desc="Testing"):
                images, labels = images.to(device), labels.to(device)
                outputs = model(images)
                _, predicted = torch.max(outputs.data, 1)
                total += labels.size(0)
                correct += (predicted == labels).sum().item()

        epoch_acc = 100 * correct / total
        if epoch_acc > best_acc:
            best_acc = epoch_acc
            torch.save(model.state_dict(), model_save_path)
            print(f"New best model saved to {model_save_path} with accuracy {best_acc:.2f}%")

        print(f"Epoch {epoch + 1}/{epochs} | Test Acc: {epoch_acc:.2f}% | Best Acc: {best_acc:.2f}%")

    return model


if __name__ == "__main__":
    # Parameters
    batch_size = 32
    target_batch_size = 512
    num_classes = 37
    epochs = 20
    image_sizes = [400,416]  #384

    # Create directory for saved models if it doesn't exist
    os.makedirs("saved_models", exist_ok=True)

    for img_size in image_sizes:
        print(f"\n{'=' * 50}")
        print(f"Starting training for image size: {img_size}")
        print(f"{'=' * 50}")

        # Set up model save path
        model_save_path = f"saved_models/vit_b16_pets_imagesize{img_size}.pth"

        # Load data and model
        train_loader, test_loader = load_pets_dataset(batch_size, img_size)
        model = init_vit_model(num_classes, img_size)

        # Fine-tune
        model = fine_tune(
            model,
            train_loader,
            test_loader,
            model_save_path,
            epochs=epochs,
            lr=0.001,
            batch_size=batch_size,
            target_batch_size=target_batch_size
        )

        print(f"\nCompleted training for image size {img_size}. Model saved to {model_save_path}")
