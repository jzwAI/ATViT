# ==================== Dataset Configuration ====================

DATASET_CONFIG = {
    "cifar10": {
        "num_classes": 10,
        "model_base_path": "vit_b16_cifar10_imagesize",
        "mean": [0.4914, 0.4822, 0.4465],
